# Postgres (en local via Coolify, ou un Postgres de dev)
DATABASE_URL=postgres://user:password@localhost:5432/photos

# Dossier de stockage des photos.
# En dev : ./data/photos  | En prod (Coolify) : /data/photos (volume monté)
STORAGE_DIR=./data/photos

# Secret de signature des sessions (générer : openssl rand -base64 32)
AUTH_SECRET=
# URL publique du site (sert à construire les liens de connexion)
APP_URL=http://localhost:3000

# E-mail transactionnel (Resend). Sans clé, le lien magic-link est loggé en console (dev).
RESEND_API_KEY=
MAIL_FROM=Studio <bonjour@ton-domaine.fr>
